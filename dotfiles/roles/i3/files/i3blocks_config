# i3blocks configuration file
#
# The i3blocks man page describes the usage of the binary,
# and its website describes the configuration:
#
#     https://vivien.github.io/i3blocks


# Global properties
separator=false
separator_block_width=15

[running_music]
command=if [ $button ]; then i3-msg exec /home/ruffiely/.scripts/play-music; else /home/ruffiely/.scripts/show-music; fi
interval=1

[time]
command=date '+%A %d.%B %Y %H:%M'
interval=1

[shutdown]
full_text=
command=rofi -show p -modi p:$HOME/.rofi-power-menu 
#command=exec i3-nagbar -t warning -m 'Do you really want to shutdown the system?' -B '' 'systemctl poweroff' -f pango:System San Francisco Display 14 >> /dev/null
